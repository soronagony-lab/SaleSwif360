# URL publique du site (SEO : canonical, Open Graph). Ex. https://sale-swif360.vercel.app
VITE_SITE_URL=

# InsForge (auth admin + données) — même jeu sur Vercel : Production, Preview, Development
VITE_INSFORGE_URL=
VITE_INSFORGE_ANON_KEY=

# E-mails autorisés pour l’admin (séparés par des virgules). Obligatoire pour connexion / inscription admin.
# Ex. : admin@mondomaine.ci,autre@mail.com
VITE_ADMIN_EMAILS=
# Optionnel — métadonnée google-site-verification (Search Console)
VITE_GOOGLE_SITE_VERIFICATION=

# Optionnel — branchez un projet Supabase pour la persistance cloud.
# Sans ces variables, l’app utilise le state React + localStorage.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
