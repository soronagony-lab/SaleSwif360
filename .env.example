# URL publique du site (SEO : canonical, Open Graph). Ex. https://sale-swif360.vercel.app
VITE_SITE_URL=

# InsForge (auth admin + données) — même jeu sur Vercel : Production, Preview, Development
# URL : celle du projet InsForge (sans / à la fin). Clé : « Anonymous / public » du dashboard, pas la clé secrète serveur.
# Après modification sur Vercel : redéployer (les variables VITE_* sont injectées au build).
VITE_INSFORGE_URL=
VITE_INSFORGE_ANON_KEY=

# E-mails autorisés pour l’admin (séparés par des virgules). Obligatoire pour connexion / inscription admin.
# Ex. : admin@mondomaine.ci,autre@mail.com
VITE_ADMIN_EMAILS=
# Optionnel — métadonnée google-site-verification (Search Console)
VITE_GOOGLE_SITE_VERIFICATION=

# Référence : sitemap statique public/sitemap.xml + robots.txt (à ajuster si domaine custom).
# GA4 : renseignez aussi l’ID dans l’admin (Configuration) pour activer le suivi SPA.

# Optionnel — devise ISO 4217 pour Meta Pixel (ViewContent, InitiateCheckout, Purchase). Défaut : XOF
# VITE_META_PIXEL_CURRENCY=USD

# Optionnel — branchez un projet Supabase pour la persistance cloud.
# Sans ces variables, l’app utilise le state React + localStorage.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
